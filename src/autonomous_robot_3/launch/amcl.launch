<launch>
    <!-- Argument Definitions -->
    <arg name="scan_topic" default="/scan"/>
    <arg name="initial_pose_x" default="0.0"/>
    <arg name="initial_pose_y" default="0.0"/>
    <arg name="initial_pose_a" default="0.0"/>
    <arg name="odom_model_type" default="omni"/>
    <arg name="move_forward_only" default="false"/>
    <arg name="rvizconfig" default="$(find autonomous_robot_3)/rviz/config3.rviz"/>
    
     <!-- Launch MoveIt -->
  <!--<include file="$(find tray_moveit_config)/launch/move_group.launch" />-->
    

    <!-- Include Gazebo Launch -->
    <include file="$(find autonomous_robot_3)/launch/test.launch" /> 
    
  
 
  
    <!-- Map Server -->
    <node name="map_server" pkg="map_server" type="map_server" args="$(find autonomous_robot_3)/maps/my_map_2.yaml" output="screen" />
    
    <!-- Static Transform Publisher for map to odom -->
    <!--<node pkg="tf" type="static_transform_publisher" name="odom_map_broadcaster" args="0 0 0 0 0 0 /map /odom 100" />--> 

    <!-- AMCL Localization -->
    <node pkg="amcl" type="amcl" name="amcl" respawn="false">
        <param name="use_map_topic" value="true"/>
        <param name="odom_model_type" value="$(arg odom_model_type)"/>
        <param name="odom_alpha5" value="0.1"/>
        <param name="gui_publish_rate" value="10.0"/>
        <param name="laser_max_beams" value="60"/>
        <param name="laser_max_range" value="12.0"/>
        <param name="min_particles" value="2000"/>
        <param name="max_particles" value="5000"/>
        <param name="kld_err" value="0.05"/>
        <param name="kld_z" value="0.99"/>
        <param name="odom_alpha1" value="0.2"/>
        <param name="odom_alpha2" value="0.2"/>
        <param name="odom_alpha3" value="0.8"/>
        <param name="odom_alpha4" value="0.2"/>
        <param name="laser_z_hit" value="0.5"/>
        <param name="laser_z_short" value="0.05"/>
        <param name="laser_z_max" value="0.05"/>
        <param name="laser_z_rand" value="0.5"/>
        <param name="laser_sigma_hit" value="0.2"/>
        <param name="laser_lambda_short" value="0.1"/>
        <param name="laser_model_type" value="likelihood_field"/>
        <param name="laser_likelihood_max_dist" value="2.0"/>
        <param name="update_min_d" value="0.25"/>
        <param name="update_min_a" value="0.2"/>
        <param name="odom_frame_id" value="odom"/>
        <param name="base_frame_id" value="base_link"/>
        <param name="global_frame_id" value="map"/>
        <param name="resample_interval" value="0.5"/>
        <param name="transform_tolerance" value="1.0"/>
        <param name="recovery_alpha_slow" value="0.0"/>
        <param name="recovery_alpha_fast" value="0.0"/>
        <param name="initial_pose_x" value="$(arg initial_pose_x)"/>
        <param name="initial_pose_y" value="$(arg initial_pose_y)"/>
        <param name="initial_pose_a" value="$(arg initial_pose_a)"/>
        <remap from="scan" to="$(arg scan_topic)"/>
        <remap from="map" to="/map"/>
    </node>

    <!-- Move Base -->
    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <rosparam file="$(find autonomous_robot_3)/config/costmap_common_params.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find autonomous_robot_3)/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find autonomous_robot_3)/config/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find autonomous_robot_3)/config/global_costmap_params.yaml" command="load" />
        <rosparam file="$(find autonomous_robot_3)/config/base_local_planner_params.yaml" command="load" /> 

        <remap from="cmd_vel" to="cmd_vel"/>
        <remap from="odom" to="odom"/>
        <remap from="scan" to="$(arg scan_topic)"/>
        <param name="move_base/DWAPlannerROS/yaw_goal_tolerance" value="1.0"/>
        <param name="move_base/DWAPlannerROS/xy_goal_tolerance" value="1.0"/>    
    </node>

    <!-- RViz -->
    <node name="rviz_node" pkg="rviz" args="-d $(arg rvizconfig)" type="rviz" required="true"/> 
    
  
     
     
</launch>
  

