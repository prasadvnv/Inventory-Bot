<launch>
  <param
    name="robot_description"
    textfile="$(find autonomous_robot_3)/urdf/autonomous_robot_3.urdf" />
  
  <node name="spawn_model" pkg="gazebo_ros" type="spawn_model"
        args="-file $(find autonomous_robot_3)/urdf/autonomous_robot_3.urdf -urdf -model autonomous_robot_3 -x 0 -y 0 -z 1.0"
        output="screen" />

<node name="joint_state_publisher" pkg = "joint_state_publisher" type ="joint_state_publisher"/>
<node name="robot_state_publisher" pkg = "robot_state_publisher" type ="robot_state_publisher" respawn="false" output="screen"/>

	<include file="$(find gazebo_ros)/launch/empty_world.launch">

    <!-- Load the controller parameters into the /robot namespace -->
  <!--<rosparam file="$(find autonomous_robot_3)/config/controllers.yaml" command="load"/>-->

  <!-- Launch the controller manager -->
  <!--<node name="controller_manager" pkg="controller_manager" type="controller_manager"  respawn="false" output="screen"/>-->
  
  <!-- Launch the controller spawner -->
  <!--<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" args="joint_state_controller joint_tray_controller"/>-->
  
  
  <!--<node name="tf_footprint_base" pkg="tf" type="static_transform_publisher" args="0 0 0 0 0 0 base_link base_footprint 40" />-->


  <!--<node name="odom_tf_broadcaster" pkg="tf" type="static_transform_publisher" args="0 0 0 0 0 0 odom base_link 100" />-->
  



 
    <arg name="world_name" value="$(find autonomous_robot_3)/worlds/no_roof_small_warehouse.world"/>
  
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>
  <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" name="teleop" output="screen"/>  
  
  
 
</launch>
  

